    print(f"Signal std:  {valid_df['signal'].std():.6f}")
    print(f"Signal min:  {valid_df['signal'].min():.6f}")
    print(f"Signal max:  {valid_df['signal'].max():.6f}")

    signal_df.write_parquet(output_path)
